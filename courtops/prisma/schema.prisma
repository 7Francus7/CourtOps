generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Club {
  id                 String           @id @default(uuid())
  name               String
  slug               String           @unique
  logoUrl            String?
  themeColor         String?          @default("#0080ff")
  phone              String?
  address            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  timezone           String           @default("America/Argentina/Buenos_Aires")
  currency           String           @default("ARS")
  openTime           String           @default("14:00")
  closeTime          String           @default("00:30")
  slotDuration       Int              @default(90)
  cancelHours        Int              @default(6)
  plan               String           @default("BASIC")
  subscriptionStatus String           @default("TRIAL")
  nextBillingDate    DateTime?
  maxCourts          Int              @default(2)
  maxUsers           Int              @default(3)
  hasKiosco          Boolean          @default(false)
  hasOnlinePayments  Boolean          @default(false)
  hasAdvancedReports Boolean          @default(false)
  allowCredit        Boolean          @default(true)
  hasCustomDomain    Boolean          @default(false)
  hasTournaments     Boolean          @default(false)
  hasWhatsApp        Boolean          @default(false)
  hasWaivers         Boolean          @default(false)
  mpAlias            String?
  mpCvu              String?
  mpAccessToken      String?
  mpPublicKey        String?
  mpRefreshToken     String?
  mpUserId           String?
  mpConnectedAt      DateTime?
  bookingDeposit     Float            @default(0)
  mpPreapprovalId    String?
  platformPlanId     String?
  deletedAt          DateTime?
  auditLogs          AuditLog[]
  bookings           Booking[]
  cashRegisters      CashRegister[]
  clients            Client[]
  platformPlan       PlatformPlan?    @relation(fields: [platformPlanId], references: [id])
  courts             Court[]
  employees          Employee[]
  membershipPlans    MembershipPlan[]
  notifications      Notification[]
  priceRules         PriceRule[]
  products           Product[]
  referrals          Referral[]
  teachers           Teacher[]
  tournaments        Tournament[]
  transactions       Transaction[]
  users              User[]
  waitingList        WaitingList[]
  waivers            Waiver[]

  @@map("Club")
}

model PlatformPlan {
  id        String   @id @default(cuid())
  name      String   @unique
  price     Float
  setupFee  Float    @default(0)
  features  String
  mpBackUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clubs     Club[]
}

model User {
  id                      String     @id @default(uuid())
  email                   String     @unique
  password                String
  name                    String
  role                    String
  clubId                  String?
  lastNotificationsReadAt DateTime?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  deletedAt               DateTime?
  tokenVersion            Int        @default(0)
  auditLogs               AuditLog[]
  club                    Club?      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("User")
}

model Employee {
  id          String    @id @default(uuid())
  clubId      String
  name        String
  pin         String
  permissions String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("Employee")
}

model Court {
  id                Int               @id @default(autoincrement())
  clubId            String
  name              String
  surface           String?
  isIndoor          Boolean           @default(false)
  isActive          Boolean           @default(true)
  sortOrder         Int               @default(0)
  sport             String            @default("PADEL")
  duration          Int               @default(90)
  deletedAt         DateTime?
  bookings          Booking[]
  club              Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  priceRules        PriceRule[]
  tournamentMatches TournamentMatch[]
  waitingList       WaitingList[]

  @@unique([id, clubId], name: "id_clubId")
  @@map("Court")
}

model Client {
  id                  Int               @id @default(autoincrement())
  clubId              String
  name                String
  phone               String
  notes               String?
  createdAt           DateTime          @default(now())
  email               String?
  deletedAt           DateTime?
  membershipStatus    String            @default("NONE")
  membershipExpiresAt DateTime?
  category            String?
  skillLevel          Float?            @default(0)
  position            String?
  preferredSchedule   String?
  bookings            Booking[]
  club                Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberships         Membership[]
  referralsReceived   Referral[]        @relation("Referred")
  referralsMade       Referral[]        @relation("Referrer")
  tournamentTeams1    TournamentTeam[]  @relation("TeamPlayer1")
  tournamentTeams2    TournamentTeam[]  @relation("TeamPlayer2")
  transactions        Transaction[]
  waitingList         WaitingList[]
  waiverSignatures    WaiverSignature[]

  @@unique([id, clubId], name: "id_clubId")
  @@unique([clubId, phone])
  @@index([clubId, name])
  @@map("Client")
}

model PriceRule {
  id          Int       @id @default(autoincrement())
  clubId      String
  courtId     Int?
  name        String?
  priority    Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?
  daysOfWeek  String?
  startTime   String
  endTime     String
  price       Float
  memberPrice Float?
  club        Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  court       Court?    @relation(fields: [courtId], references: [id], onDelete: Cascade)

  @@unique([id, clubId], name: "id_clubId")
  @@index([clubId, priority])
  @@index([courtId])
  @@map("PriceRule")
}

model Booking {
  id            Int             @id @default(autoincrement())
  clubId        String
  courtId       Int
  clientId      Int?
  publicToken   String?
  recurringId   String?
  startTime     DateTime
  endTime       DateTime
  price         Float
  status        String
  paymentStatus String
  paymentMethod String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  bookingType   String          @default("NORMAL")
  teacherId     String?
  guestName     String?
  guestPhone    String?
  reminderSent  Boolean         @default(false)
  checkinToken  String?         @unique
  checkedInAt   DateTime?
  isOpenMatch   Boolean         @default(false)
  matchLevel    String?
  matchGender   String?
  maxPlayers    Int             @default(4)
  description   String?
  client        Client?         @relation(fields: [clientId], references: [id])
  club          Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  court         Court           @relation(fields: [courtId], references: [id])
  teacher       Teacher?        @relation(fields: [teacherId], references: [id])
  items         BookingItem[]
  players       BookingPlayer[]
  transactions  Transaction[]

  @@unique([id, clubId], name: "id_clubId")
  @@index([clubId, startTime])
  @@index([clubId, status])
  @@index([clubId, clientId])
  @@index([clubId, deletedAt])
  @@index([clubId, courtId, startTime])
  @@index([clientId, createdAt])
  @@index([publicToken])
  @@map("Booking")
}

model BookingItem {
  id         Int      @id @default(autoincrement())
  bookingId  Int
  productId  Int?
  quantity   Int      @default(1)
  unitPrice  Float    @default(0)
  playerName String?
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  product    Product? @relation(fields: [productId], references: [id])

  @@map("BookingItem")
}

model Product {
  id           Int               @id @default(autoincrement())
  clubId       String
  name         String
  category     String
  cost         Float
  price        Float
  memberPrice  Float?
  stock        Int
  minStock     Int               @default(5)
  imageUrl     String?
  isActive     Boolean           @default(true)
  deletedAt    DateTime?
  bookingItems BookingItem[]
  club         Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  transactions TransactionItem[]

  @@unique([id, clubId], name: "id_clubId")
  @@index([clubId])
  @@map("Product")
}

model BookingPlayer {
  id            Int     @id @default(autoincrement())
  bookingId     Int
  name          String
  phone         String?
  amount        Float   @default(0)
  isPaid        Boolean @default(false)
  paymentMethod String?
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("BookingPlayer")
}

model CashRegister {
  id              Int           @id @default(autoincrement())
  clubId          String
  date            DateTime      @default(now())
  openedAt        DateTime      @default(now())
  closedAt        DateTime?
  startAmount     Float         @default(0)
  endAmountCash   Float?
  endAmountTransf Float?
  status          String
  club            Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@unique([id, clubId], name: "id_clubId")
  @@index([clubId, date])
  @@map("CashRegister")
}

model Transaction {
  id             Int               @id @default(autoincrement())
  cashRegisterId Int
  clientId       Int?
  type           String
  category       String
  amount         Float
  method         String
  description    String?
  createdAt      DateTime          @default(now())
  bookingId      Int?
  clubId         String            @default("")
  booking        Booking?          @relation(fields: [bookingId], references: [id])
  cashRegister   CashRegister      @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  client         Client?           @relation(fields: [clientId], references: [id])
  club           Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  items          TransactionItem[]

  @@unique([id, clubId], name: "id_clubId")
  @@index([cashRegisterId])
  @@index([bookingId])
  @@index([clientId])
  @@index([createdAt])
  @@index([clubId, type, createdAt])
  @@map("Transaction")
}

model TransactionItem {
  id            Int         @id @default(autoincrement())
  transactionId Int
  productId     Int?
  quantity      Int
  unitPrice     Float
  subtotal      Float
  product       Product?    @relation(fields: [productId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("TransactionItem")
}

model AuditLog {
  id        String   @id @default(uuid())
  clubId    String
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([id, clubId])
  @@index([clubId, createdAt])
  @@index([clubId, entity, entityId])
  @@map("AuditLog")
}

model WaitingList {
  id        Int       @id @default(autoincrement())
  clubId    String
  date      DateTime
  startTime DateTime?
  endTime   DateTime?
  courtId   Int?
  clientId  Int?
  name      String
  phone     String
  notes     String?
  status    String    @default("PENDING")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  client    Client?   @relation(fields: [clientId], references: [id])
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  court     Court?    @relation(fields: [courtId], references: [id])

  @@index([clubId, date])
  @@map("WaitingList")
}

model MembershipPlan {
  id                  String       @id @default(uuid())
  clubId              String
  name                String
  description         String?
  price               Float
  durationDays        Int          @default(30)
  discountPercent     Float        @default(0)
  discountFixed       Float        @default(0)
  mpPreapprovalPlanId String?
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?
  memberships         Membership[]
  club                Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("MembershipPlan")
}

model Membership {
  id              String         @id @default(uuid())
  clientId        Int
  planId          String
  startDate       DateTime       @default(now())
  endDate         DateTime
  pricePaid       Float
  status          String         @default("ACTIVE")
  mpPreapprovalId String?
  createdAt       DateTime       @default(now())
  deletedAt       DateTime?
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan            MembershipPlan @relation(fields: [planId], references: [id])

  @@index([clientId, status])
  @@map("Membership")
}

model Tournament {
  id          String               @id @default(uuid())
  clubId      String
  name        String
  startDate   DateTime
  endDate     DateTime?
  status      String               @default("DRAFT")
  description String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  deletedAt   DateTime?
  club        Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  categories  TournamentCategory[]

  @@map("Tournament")
}

model TournamentCategory {
  id           String            @id @default(uuid())
  tournamentId String
  name         String
  gender       String?
  price        Float
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  groups       TournamentGroup[]
  matches      TournamentMatch[]
  teams        TournamentTeam[]

  @@map("TournamentCategory")
}

model TournamentTeam {
  id            String             @id @default(uuid())
  categoryId    String
  name          String
  player1Id     Int?
  player1Name   String
  player1Phone  String?
  player2Id     Int?
  player2Name   String
  player2Phone  String?
  points        Int                @default(0)
  matchesPlayed Int                @default(0)
  setsWon       Int                @default(0)
  gamesWon      Int                @default(0)
  groupId       String?
  matchAway     TournamentMatch[]  @relation("AwayTeam")
  matchHome     TournamentMatch[]  @relation("HomeTeam")
  category      TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  group         TournamentGroup?   @relation(fields: [groupId], references: [id])
  player1       Client?            @relation("TeamPlayer1", fields: [player1Id], references: [id])
  player2       Client?            @relation("TeamPlayer2", fields: [player2Id], references: [id])

  @@map("TournamentTeam")
}

model TournamentGroup {
  id         String             @id @default(uuid())
  categoryId String
  name       String
  category   TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  teams      TournamentTeam[]

  @@map("TournamentGroup")
}

model TournamentMatch {
  id         String             @id @default(uuid())
  categoryId String
  round      String
  homeTeamId String?
  awayTeamId String?
  courtId    Int?
  startTime  DateTime?
  endTime    DateTime?
  homeScore  String?
  awayScore  String?
  winnerId   String?
  status     String             @default("SCHEDULED")
  awayTeam   TournamentTeam?    @relation("AwayTeam", fields: [awayTeamId], references: [id])
  category   TournamentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  court      Court?             @relation(fields: [courtId], references: [id])
  homeTeam   TournamentTeam?    @relation("HomeTeam", fields: [homeTeamId], references: [id])

  @@map("TournamentMatch")
}

model SystemNotification {
  id        String    @id @default(uuid())
  title     String
  message   String
  type      String    @default("INFO")
  target    String    @default("ALL")
  isActive  Boolean   @default(true)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("SystemNotification")
}

model Notification {
  id          String   @id @default(uuid())
  clubId      String
  type        String
  title       String
  description String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  club        Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, isRead])
  @@index([clubId, createdAt])
  @@map("Notification")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("PasswordResetToken")
}

model Waiver {
  id         String            @id @default(uuid())
  clubId     String
  title      String
  content    String
  isActive   Boolean           @default(true)
  isRequired Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  club       Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  signatures WaiverSignature[]

  @@index([clubId])
  @@map("Waiver")
}

model WaiverSignature {
  id         String   @id @default(uuid())
  waiverId   String
  clientId   Int?
  guestName  String?
  guestPhone String?
  signature  String
  signedAt   DateTime @default(now())
  ipAddress  String?
  client     Client?  @relation(fields: [clientId], references: [id])
  waiver     Waiver   @relation(fields: [waiverId], references: [id], onDelete: Cascade)

  @@index([waiverId])
  @@index([clientId])
  @@map("WaiverSignature")
}

model Referral {
  id            String    @id @default(uuid())
  clubId        String
  referrerId    Int
  referredId    Int?
  referredName  String?
  referredPhone String?
  code          String    @unique
  status        String    @default("PENDING")
  rewardAmount  Float?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  club          Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  referred      Client?   @relation("Referred", fields: [referredId], references: [id])
  referrer      Client    @relation("Referrer", fields: [referrerId], references: [id])

  @@index([clubId])
  @@index([referrerId])
  @@index([code])
  @@map("Referral")
}

model WebhookQueue {
  id          String    @id @default(uuid())
  payload     String
  queryParams String?
  headers     String?
  status      String    @default("PENDING")
  retryCount  Int       @default(0)
  maxRetries  Int       @default(5)
  nextRetryAt DateTime  @default(now())
  lastError   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status, nextRetryAt])
  @@index([status, retryCount])
  @@map("WebhookQueue")
}

model Teacher {
  id        String    @id @default(uuid())
  clubId    String
  name      String
  phone     String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bookings  Booking[]
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId])
  @@map("Teacher")
}
